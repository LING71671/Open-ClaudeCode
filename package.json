    "@types/marked": "^6.0.0",
    "@types/node": "^22.14.0",
    "@types/picomatch": "^4.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.1.0",
    "@types/react-reconciler": "^0.28.9",
    "@types/semver": "^7.7.0",
    "@types/shell-quote": "^1.7.5",
    "@types/stack-utils": "^2.0.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "bun-types": "^1.2.8",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "prettier": "^3.5.3",
