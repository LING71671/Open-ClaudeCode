{
  "name": "open-claude-code",
  "version": "2.1.88",
  "description": "Open-source reconstruction of Claude Code - for learning and research only",
  "type": "module",
  "main": "src/main.tsx",
  "bin": {
    "claude": "dist/cli.js"
  },
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "build": "bun run build:cli",
    "build:cli": "bun build src/main.tsx --outfile dist/cli.js --target node --minify --sourcemap=linked --define 'process.env.NODE_ENV=\"production\"'",
    "build:dev": "bun build src/main.tsx --outfile dist/cli.js --target node --sourcemap=linked --define 'process.env.NODE_ENV=\"development\"'",
    "dev": "bun run src/main.tsx",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\""
  },
  "keywords": ["claude", "anthropic", "cli", "ai", "coding-assistant"],
  "author": "Anthropic PBC (original), Open-ClaudeCode contributors (reconstruction)",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/LING71671/Open-ClaudeCode",
  "repository": {
    "type": "git",
    "url": "https://github.com/LING71671/Open-ClaudeCode.git"
  },
  "bugs": {
    "url": "https://github.com/LING71671/Open-ClaudeCode/issues"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.3",
    "@anthropic-ai/sdk": "^0.39.0",
    "@commander-js/extra-typings": "^13.1.0",
    "@growthbook/growthbook": "^1.3.1",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.200.0",
    "@opentelemetry/core": "^2.0.0",
    "@opentelemetry/resources": "^2.0.0",
    "@opentelemetry/sdk-logs": "^0.200.0",
    "@opentelemetry/sdk-metrics": "^2.0.0",
    "@opentelemetry/sdk-trace-base": "^2.0.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "auto-bind": "^5.0.1",
    "axios": "^1.8.4",
    "bidi-js": "^1.0.3",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "cli-boxes": "^3.0.0",
    "code-excerpt": "^4.0.0",
    "diff": "^7.0.0",
    "emoji-regex": "^10.4.0",
    "env-paths": "^3.0.0",
    "execa": "^9.5.2",
    "figures": "^6.1.0",
    "fuse.js": "^7.1.0",
    "get-east-asian-width": "^1.3.0",
    "google-auth-library": "^9.15.1",
    "ignore": "^7.0.3",
    "indent-string": "^5.0.0",
    "lodash-es": "^4.17.21",
    "lru-cache": "^11.0.2",
    "marked": "^15.0.7",
    "p-map": "^7.0.3",
    "picomatch": "^4.0.2",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-compiler-runtime": "^19.1.0-rc.1",
